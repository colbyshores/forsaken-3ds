# ============================================================
# ForsakenX 3DS Port — .gitignore
# Only code, headers, configs, makefiles, and docs are tracked.
# ============================================================

# ---- Compiled objects and binaries ----
*.o
*.a
*.so
*.dll
*.exe
*.elf
*.3dsx
*.smdh
*.map
*.bin
*.cia
gmon.out

# ---- 3DS build artifacts ----
build_3ds/
forsaken3ds.*
.romfs_staging/
forsaken_*.log

# ---- PC build artifacts ----
projectx*
libs*
unix*
mingw*

# ---- Game data / assets (large binaries, not code) ----
# Retail game data directories (textures, models, sounds, levels)
Data/
data/
Demos/
Pilots/
pilots/
romfs/
savegame/
logs/
DATA.TAG
data1.cab

# Config directories (lowercase = runtime copies, uppercase = tracked overrides)
configs/

# ---- Asset file types ----
*.bmp
*.BMP
*.png
*.PNG
*.jpg
*.jpeg
*.gif
*.tga
*.pcx
*.ico
*.wav
*.WAV
*.mp3
*.ogg
*.mid
*.ppm
*.PPM

# ---- Model / level data ----
*.mx
*.mxa
*.cob
*.dat

# ---- picaGL (separate submodule/repo) ----
picaGL/

# ---- IDE and editor files ----
*.vcxproj*
*.sln
*.suo
*.user
*.swp
*.swo
*~
.vscode/
.idea/

# ---- Shell scripts (development utilities) ----
*.sh

# ---- Misc ----
net_test/

# ---- Exceptions: tracked files that match patterns above ----
# Lua game scripts (code, not assets)
!scripts/
!scripts/**
# Configs override for 3DS
!Configs/
!Configs/main.txt
# CI workflows
!.github/
!.github/**
# HD texture regeneration pipeline (tooling shipped with the port)
!regen_hd_old_4k.sh
# Banner audio rebuild (deterministic — fetches YT clip + demucs)
!build_banner_audio.sh

# CIA build pipeline — fetched binaries (run `make tools-fetch`)
tools/

# Nintendo firmware blob — bundled into the CIA for personal use only.
# Dump from your own 3DS (DSP1 by zoogie) and place at this path before
# building the CIA. Never commit this file to a public repository.
assets/dspfirm.cdc

# Build artifacts
*.cia
*.bnr

# Python bytecode caches (from extract/regen helper scripts)
__pycache__/
*.pyc

# HD-texture intermediate output (scratch from older runs of the regen
# pipeline; current pipeline writes to romfs/hd_old/ which IS tracked-as-
# absent via romfs/ rules)
romfs_hd/

# Per-developer debug overlay (ships in Configs/debug.txt locally; never commit)
Configs/debug.txt

# Top-level symlinks pointing into Data/Pilots/Configs source trees.
# The trailing-slash forms below match directories only, not symlinks,
# so we list these explicitly.
/configs
/data
/pilots

# CIA build assets (small + needed to build the .cia)
!assets/icon.png
!assets/banner.png
!assets/banner.wav
forsaken_stereo.txt
